{
  "name": "rekishi-shorts",
  "version": "0.1.0",
  "description": "受験生向け歴史ショート動画の自動生成サービス (monorepo root)",
  "private": true,
  "type": "module",
  "scripts": {
    "typecheck": "pnpm -r typecheck",
    "research": "pnpm --filter @rekishi/pipeline research",
    "draft": "pnpm --filter @rekishi/pipeline draft",
    "build": "pnpm --filter @rekishi/pipeline build",
    "generate": "pnpm --filter @rekishi/pipeline generate",
    "studio": "pnpm --filter @rekishi/renderer studio",
    "post": "pnpm --filter @rekishi/publisher post",
    "kosei-animation": "pnpm --filter @rekishi/pipeline exec tsx src/cli.ts kosei-animation-generate"
  },
  "packageManager": "pnpm@10.30.2",
  "engines": {
    "node": ">=20"
  }
}
