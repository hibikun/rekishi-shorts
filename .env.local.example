# ========== Phase 0 で必要な API キー ==========

# Google Gemini (台本・シーン設計・画像生成)
GEMINI_API_KEY=your_gemini_api_key_here

# ElevenLabs (日本語 TTS)
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
# voice_id は https://api.elevenlabs.io/v1/voices で取得。日本語ナレーションに適した男性/女性voiceを指定
ELEVENLABS_VOICE_ID=your_voice_id_here

# OpenAI (Whisper 字幕タイムスタンプ)
OPENAI_API_KEY=your_openai_api_key_here

# ========== モデル設定（変更可） ==========
GEMINI_SCRIPT_MODEL=gemini-3.1-pro-preview
GEMINI_SCENE_MODEL=gemini-3.1-flash-lite-preview
GEMINI_IMAGE_MODEL=gemini-3.1-flash-image-preview
GEMINI_METADATA_MODEL=gemini-3.1-flash-lite-preview
ELEVENLABS_MODEL=eleven_multilingual_v2
WHISPER_MODEL=whisper-1

# ========== YouTube Data API v3 (Phase 2: 自動投稿) ==========
# セットアップ手順: docs/phases/youtube-setup.md
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=
# 任意: 複数チャンネル運用時に明示。空でよい
YOUTUBE_CHANNEL_ID=
