{
  "name": "@rekishi/pipeline",
  "version": "0.1.0",
  "description": "AI pipeline (script → TTS → assets → captions)",
  "type": "module",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./package.json": "./package.json"
  },
  "scripts": {
    "generate": "tsx src/cli.ts generate",
    "script-only": "tsx src/cli.ts script-only",
    "tts-only": "tsx src/cli.ts tts-only",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@rekishi/shared": "workspace:*",
    "@rekishi/renderer": "workspace:*",
    "@google/genai": "^1.50.0",
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "dotenv": "^16.5.0",
    "openai": "^4.86.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
