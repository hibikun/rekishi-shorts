# remotion
packages/renderer/out/
packages/renderer/public/

# ライセンス管理する BGM/SFX 等の音源は各自ローカルに配置（コミット禁止）
packages/channels/*/assets/bgm/
packages/channels/*/assets/sfx/
# 同じくライセンス管理する背景画像も各自ローカルに配置（コミット禁止）
packages/channels/*/assets/backgrounds/
# TTS 生成済みナレーション (再生成可能、サイズも MB オーダーなのでローカル保管)
packages/channels/*/assets/audio/

# manabilab-canva のジョブ作業ディレクトリは各自ローカルに保管（生成物のみ）
packages/channels/manabilab-canva/jobs/*
!packages/channels/manabilab-canva/jobs/.gitkeep

# self-motivation のジョブ作業ディレクトリは各自ローカルに保管（生成物のみ）
packages/channels/self-motivation/jobs/*
!packages/channels/self-motivation/jobs/.gitkeep

